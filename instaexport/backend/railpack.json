{
  "$schema": "https://schema.railpack.com",
  "provider": "node",
  "install": {
    "aptPackages": [
      "chromium",
      "chromium-driver",
      "fonts-noto-color-emoji",
      "fonts-noto",
      "libglib2.0-0",
      "libnss3",
      "libnspr4",
      "libdbus-1-3",
      "libatk1.0-0",
      "libatk-bridge2.0-0",
      "libcups2",
      "libdrm2",
      "libxcb1",
      "libxkbcommon0",
      "libx11-6",
      "libxcomposite1",
      "libxdamage1",
      "libxext6",
      "libxfixes3",
      "libxrandr2",
      "libgbm1",
      "libpango-1.0-0",
      "libcairo2",
      "libasound2"
    ]
  },
  "deploy": {
    "startCommand": "node src/index.js",
  }
}
